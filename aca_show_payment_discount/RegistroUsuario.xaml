<Window x:Class="aca_show_payment_discount.RegistroUsuario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:aca_show_payment_discount"
        mc:Ignorable="d"
        Title="RegistroUsuario" Height="500" Width="800" Background= "YellowGreen">
    <Grid>
        <StackPanel Margin="0">
        <TextBlock Text="Registro de Usuario"  FontSize="20" 
                   HorizontalAlignment="Center"></TextBlock>
        <Image Source="\assets\CUN.svg.png"
               Width="200" Height="50" VerticalAlignment="Top" Margin="0,0,0,0"></Image>
            
            <TextBlock Text="Usuario" HorizontalAlignment="Center" FontSize="15"></TextBlock>
            <TextBox  x:Name="vUsuario"  FontSize="15" Height="30" Width="300"></TextBox>
            <TextBlock x:Name="lblResultado" HorizontalAlignment="Center" ></TextBlock>
            <TextBlock Text="Edad" HorizontalAlignment="Center" FontSize="15"></TextBlock>
            <TextBox x:Name="intEdad" FontSize="15" Height="30" Margin="0,10,0,0" Width="300"></TextBox>
            <TextBlock x:Name="lblResultado2" HorizontalAlignment="Center" ></TextBlock>
            <TextBlock Text="DNI" HorizontalAlignment="Center" FontSize="15"></TextBlock>
            <TextBox x:Name="varDni" FontSize="15" Height="30" Margin="0,20,0,0" Width="300"></TextBox>
            <TextBlock x:Name="lblResultado3" HorizontalAlignment="Center"></TextBlock>
            <Button x:Name="bRegistrar" FontSize="15" Content="Registrar" Click="b_clRegistrar" Height="30" Width="130"  Margin="0,
            10,0,0"></Button>
            <TextBlock x:Name="lblResultado4" HorizontalAlignment="Center" Margin="0,20,0,0"></TextBlock>
            
            
        </StackPanel>
    </Grid>
</Window>
