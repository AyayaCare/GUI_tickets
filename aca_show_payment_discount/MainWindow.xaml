<Window x:Class="aca_show_payment_discount.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:aca_show_payment_discount"
        mc:Ignorable="d"
        Title="Sistema de Ventas" Height="520" Width="800" Background="YellowGreen">
    <Grid>
    <StackPanel Margin = "20">
        <Button Content="Registrar usuario" FontSize="15" HorizontalAlignment="Left" Click="Registrar_cl" Height="30" Width="130"></Button>
        <TextBlock Text="SISTEMA DE VENTAS DE TICKETS" FontSize="20" 
                   HorizontalAlignment="Center" Margin="0, 0, 0, 20"></TextBlock>
        <TextBlock x:Name="lblResultado5" FontSize="15" HorizontalAlignment="Left"></TextBlock>
        <TextBlock Text="DNI del Cliente" FontSize="15" HorizontalAlignment="Left" Margin="0, 20, 0, 0" ></TextBlock>
        
        <TextBox x:Name="txtDNI" Width= "300" Height="30"  HorizontalAlignment= "Left" Margin="0,5,0,15"></TextBox>
        <TextBlock x:Name="lblResultado" FontSize="15" ></TextBlock>
        <Button Content="Verificar Usuario" Height="20" Width="100" HorizontalAlignment="Left" Click="verificar_usuario_Cl"></Button>
        <Button Content="Consultar registros" Height="20" Width="120" Margin="0,10,0,0" HorizontalAlignment="Left" Click="registro_usuario_Cl"></Button>
        
        <TextBlock Text="Número de Tickets" Width= "300" Height="30" FontSize="15" HorizontalAlignment="Left"></TextBlock>
        <ComboBox x:Name="cbNumTicket" SelectionChanged="cbNumTicket_SelectionChanged" Width= "300" Height="30" HorizontalAlignment="Left">
            <ComboBoxItem Content="1 - $20.000" Tag="20000"/> 
            <ComboBoxItem Content="2 - $40.000 - (descuento de 10%)" Tag="40000"/>
            <ComboBoxItem Content="3 - $60.000 - (descuento de 15%)" Tag="60000"/>
            <ComboBoxItem Content="4 - $80.000 - (descuento de 20%)" Tag="80000"/>
            
        </ComboBox>
        <TextBlock x:Name="TotalPagar" FontSize="15"></TextBlock>
        <TextBlock Text="Máximo de 4 boletos por cliente"></TextBlock>
        <TextBlock x:Name="lblResultado3" FontSize="15" Margin="0,15,0,0"  ></TextBlock>
        <Button x:Name="btnVender" FontSize="15" Height="30" Width="130" Content="Procesar Venta" Click="btnVender_Click"/>
        
            
      
        
    </StackPanel>
        <Image Source="/assets/ChatGPT Image 22 abr 2026, 12_12_44.png" VerticalAlignment="Top" Stretch="Uniform" Margin="0,110,0,0" HorizontalAlignment="Right" Height="500" Width="500"></Image>
        <Image Source="\assets\CUN.svg.png"
               Width="300" Height="200" VerticalAlignment="Top" Margin="0,100,50,0" HorizontalAlignment="Right"></Image>
        <TextBlock  x:Name="AkaneTalk" FontSize="15" Margin="0,450,300,0" HorizontalAlignment="Center"></TextBlock>
        <TextBlock  x:Name="Resultado6" FontSize="15" HorizontalAlignment="Right" Margin="0,245,300,0"  ></TextBlock>
        
    </Grid>
</Window>
